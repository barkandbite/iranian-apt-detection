    <field name="win.eventdata.image" type="pcre2">(?i)PPBCompatCache\\ManagerCache</field>
    <description>Iranian APT: MuddyWater MuddyViper execution from persistence path</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
    <group>attack,execution,muddywater,pci_dss_10.6.1,</group>
  </rule>

  <!-- MuddyViper: Known scheduled task name -->
  <rule id="101301" level="14">
    <if_sid>4698</if_sid>
    <field name="win.eventdata.taskName" type="pcre2">(?i)ManageOnDriveUpdater</field>
