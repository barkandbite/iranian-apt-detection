# SECTION 19: IOCONTROL EXPANDED IOCS
# MITRE ATT&CK: T1071.005, T1568.002, T0859
# Group: CyberAv3ngers / BAUXITE (IRGC-CEC)
# Source: Claroty Team82 "Inside IOCONTROL" (2024)
#==============================================================================

# IOCONTROL - Known C2 IP 159.100.6.69 (Frankfurt, DE)
alert ip $HOME_NET any -> 159.100.6.69 any (msg:"Bark&Bite - Iranian APT CyberAv3ngers IOCONTROL Known C2 IP 2026"; classtype:command-and-control; sid:2000228; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# IOCONTROL - Known C2 domain
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT CyberAv3ngers IOCONTROL C2 Domain tylarion 2026"; dns.query; content:"tylarion867mino.com"; nocase; classtype:command-and-control; sid:2000229; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# IOCONTROL - Legacy C2 domain ocferda.com
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT CyberAv3ngers IOCONTROL Legacy C2 ocferda 2026"; dns.query; content:"ocferda.com"; nocase; classtype:command-and-control; sid:2000230; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# IOCONTROL - RabbitMQ management port 15672 (C2 management interface)
alert tcp $HOME_NET any -> $EXTERNAL_NET 15672 (msg:"Bark&Bite - Iranian APT CyberAv3ngers IOCONTROL RabbitMQ Mgmt 2026"; flow:to_server,established; classtype:command-and-control; sid:2000231; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# IOCONTROL - DoH to 1.1.1.1 with application/dns-json (OT anomaly)
# IOCONTROL uses GET with accept: application/dns-json, not standard dns-message
alert http $HOME_NET any -> 1.1.1.1 any (msg:"Bark&Bite - Iranian APT IOCONTROL DoH JSON Query 2026"; flow:to_server,established; content:"GET"; http_method; content:"/dns-query"; http_uri; content:"application/dns-json"; http_header; classtype:command-and-control; sid:2000232; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

#==============================================================================
# SECTION 20: UNITRONICS PCOM PROTOCOL EXPLOITATION
# MITRE ATT&CK: T0855, T0831, T1078.001
# Group: CyberAv3ngers
# Source: Claroty PCOM-Tools, CISA AA23-335A
#==============================================================================

# PCOM - Get PLC Name fingerprint (opcode 0x0C after /_OPLC magic)
# Magic bytes: 2F 5F 4F 50 4C 43 = "/_OPLC"
alert tcp $EXTERNAL_NET any -> $HOME_NET 20256 (msg:"Bark&Bite - Iranian APT CyberAv3ngers PCOM PLC Fingerprint 2026"; flow:to_server,established; content:"|2F 5F 4F 50 4C 43|"; depth:6; classtype:attempted-recon; sid:2000233; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# PCOM - Write Memory opcode 0x41 (malicious project upload)
alert tcp $EXTERNAL_NET any -> $HOME_NET 20256 (msg:"Bark&Bite - Iranian APT CyberAv3ngers PCOM Write Memory 2026"; flow:to_server,established; content:"|2F 5F 4F 50 4C 43|"; depth:6; content:"|41|"; offset:8; depth:1; classtype:attempted-admin; sid:2000234; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# PCOM - Reset Upload Password opcode 0x42 (CVE-2024-38434)
alert tcp $EXTERNAL_NET any -> $HOME_NET 20256 (msg:"Bark&Bite - Iranian APT CyberAv3ngers PCOM Password Reset CVE-2024-38434 2026"; flow:to_server,established; content:"|2F 5F 4F 50 4C 43|"; depth:6; content:"|42|"; offset:8; depth:1; reference:cve,2024-38434; classtype:attempted-admin; sid:2000235; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

#==============================================================================
# SECTION 21: CAMERA EXPLOITATION FOR BDA
# MITRE ATT&CK: T1190, T1595, T1040
# Group: CyberAv3ngers, Multiple Iranian actors
# Source: Check Point Research, VulnCheck
#==============================================================================

# Hikvision - NFS mount evasion (novel technique - portmapper contact)
# Instead of curl/wget, actors use mount to NFS-attach attacker server
alert tcp $HOME_NET any -> $EXTERNAL_NET 111 (msg:"Bark&Bite - Iranian APT Camera NFS Portmapper Evasion 2026"; flow:to_server,established; classtype:attempted-recon; sid:2000236; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# Dahua CVE-2025-31701 - RCE via Cseq header overflow
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT CyberAv3ngers Dahua CVE-2025-31701 RCE 2026"; flow:to_server,established; content:"POST"; http_method; content:"/RPC2_UploadFileWithName/"; http_uri; reference:cve,2025-31701; classtype:attempted-admin; sid:2000237; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

#==============================================================================
# SECTION 22: INDUSTRIAL PROTOCOL ABUSE
# MITRE ATT&CK: T0831, T0855, T0886
# Context: FBI/CISA confirmed Iranian targeting of hospital HVAC, water
#          systems, and building automation via industrial protocols
#==============================================================================

# BACnet Write-Property (UDP 47808) - Hospital HVAC/BAS targeting
# Service choice 0x0F = Write-Property; no authentication in standard BACnet
