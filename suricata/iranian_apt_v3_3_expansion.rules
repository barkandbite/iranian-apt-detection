# Crafty Camel - Staging domain (typosquat of INDIC Electronics)
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT Crafty Camel Staging indicelectronics.net 2025"; dns.query; content:"indicelectronics.net"; nocase; classtype:command-and-control; sid:2000224; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

