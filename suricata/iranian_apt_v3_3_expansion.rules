# Bark & Bite - Iranian APT Detection Rules: March 2026 Expansion
# Version: 3.1
# Last Updated: 2026-03-24
# Credit: Bark & Bite Security
#
# This expansion adds 95 new rules covering threat families and IOCs
# identified through deep research of 2025-2026 Iranian APT operations.
# Designed to append to bb-iran-march2026-update.rules (SID 2000131-2000193).
# New SID range: 2000194-2000288
#
# New threat coverage:
#   - MuddyViper/Fooder backdoor (MuddyWater/ESET)
#   - WezRat infostealer (Cotton Sandstorm/Check Point)
#   - UNC1549 full toolset: LIGHTRAIL, POLLBLEND, TWOSTROKE, DEEPROOT,
#     MINIBIKE, GHOSTLINE (Mandiant/Google)
#   - Handala/Void Manticore wiper + Stryker attack TTPs (Check Point)
#   - Sicarii RaaS (Check Point)
#   - WhiteLock ransomware (Cotton Sandstorm)
#   - Crafty Camel/Sosano backdoor (Proofpoint)
#   - SloppyMIO/RedKitten (HarfangLab)
#   - IOCONTROL expanded IOCs (Claroty)
#   - Unitronics PCOM protocol exploitation (Claroty)
#   - Camera exploitation for BDA (Check Point)
#   - Industrial protocol abuse: Modbus, BACnet, S7comm
#   - APT42 TAMECAT (Mandiant)
#   - APT34 Veaty/Spearal (Check Point)
#   - Dark Scepter / APT34 infrastructure (Hunt.io)
#   - GhostFetch/HTTP_VIP expanded infrastructure (Group-IB)
#   - Infy Tornado v51 blockchain DGA
#
# References:
#   - ESET: MuddyWater Snakes by the Riverbank (2025)
#   - Check Point: WezRat Deep-Dive (2024)
#   - Check Point: Handala Hack Modus Operandi (2026)
#   - Check Point: Sicarii Ransomware Truth vs Myth (2026)
#   - Mandiant/Google: UNC1549 Frontline Intelligence (2025)
#   - Check Point: Nimbus Manticore Europe (2025)
#   - HarfangLab: RedKitten AI-Accelerated Campaign (2026)
#   - Claroty Team82: IOCONTROL Inside Analysis (2024)
#   - Claroty: Unitronics PCOM Forensics (2024)
#   - Proofpoint: Crafty Camel Sosano (2025)
#   - Group-IB: Operation Olalampo (2026)
#   - Hunt.io: Dark Scepter APT34 Infrastructure (2025)

#==============================================================================
# SECTION 12: MUDDYVIPER BACKDOOR + FOODER LOADER
# MITRE ATT&CK: T1071.001, T1573.001, T1547.001, T1056.002
# Group: MuddyWater (MOIS) — Campaign Sep 2024–Mar 2025
# Source: ESET "MuddyWater: Snakes by the Riverbank"
#==============================================================================

# MuddyViper - Highly distinctive WinHTTP User-Agent (near-zero FP)
# This UA is hardcoded and unique to MuddyViper C2 communications
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater MuddyViper WinHTTP UA 2025"; flow:to_server,established; content:"A WinHTTP Example Program/1.0"; http_user_agent; classtype:command-and-control; sid:2000194; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# MuddyViper - C2 command retrieval endpoint /adad
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater MuddyViper C2 /adad 2025"; flow:to_server,established; content:"GET"; http_method; content:"/adad"; http_uri; depth:5; classtype:command-and-control; sid:2000195; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# MuddyViper - Browser data exfiltration endpoint /mq65
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater MuddyViper Exfil /mq65 2025"; flow:to_server,established; content:"/mq65"; http_uri; depth:5; classtype:trojan-activity; sid:2000196; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# MuddyViper - Credential exfiltration endpoint /rq13
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater MuddyViper CredExfil /rq13 2025"; flow:to_server,established; content:"/rq13"; http_uri; depth:5; classtype:credential-theft; sid:2000197; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# MuddyViper - Known C2 domain processplanet.org
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT MuddyWater MuddyViper C2 processplanet.org 2025"; dns.query; content:"processplanet.org"; nocase; classtype:command-and-control; sid:2000198; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# MuddyViper - Known C2 IPs (AWS-hosted infrastructure)
alert ip $HOME_NET any -> [35.175.224.64,3.95.7.142,51.16.209.105,194.11.246.78,212.232.22.136] any (msg:"Bark&Bite - Iranian APT MuddyWater MuddyViper Known C2 IP 2025"; classtype:command-and-control; sid:2000199; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

#==============================================================================
# SECTION 13: WEZRAT INFOSTEALER (COTTON SANDSTORM)
# MITRE ATT&CK: T1041, T1056.004, T1555.003, T1547.001
# Group: Cotton Sandstorm / Emennet Pasargad (IRGC-CEC)
# Source: Check Point Research "WezRat Malware Deep-Dive"
#==============================================================================

# WezRat - C2 registration beacon (highly specific URI)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Cotton Sandstorm WezRat Registration 2026"; flow:to_server,established; content:"POST"; http_method; content:"/wez/Agent/InsMch"; http_uri; classtype:command-and-control; sid:2000200; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# WezRat - Command polling endpoint /Read/
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Cotton Sandstorm WezRat Command Poll 2026"; flow:to_server,established; content:"/Read/"; http_uri; depth:6; threshold:type both, track by_src, count 5, seconds 600; classtype:command-and-control; sid:2000201; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# WezRat - Command upload endpoint
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Cotton Sandstorm WezRat UpCmd 2026"; flow:to_server,established; content:"POST"; http_method; content:"/wez/Agent/UpCmd"; http_uri; classtype:trojan-activity; sid:2000202; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# WezRat - Non-standard C2 port 8765 with "firefox" UA
alert http $HOME_NET any -> $EXTERNAL_NET 8765 (msg:"Bark&Bite - Iranian APT Cotton Sandstorm WezRat Port 8765 2026"; flow:to_server,established; content:"firefox"; http_user_agent; classtype:command-and-control; sid:2000203; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# WezRat - Known C2 domain impersonating Israeli NCSC
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT Cotton Sandstorm WezRat C2 il-cert.net 2026"; dns.query; content:"il-cert.net"; nocase; classtype:command-and-control; sid:2000204; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# WezRat - Known C2 IPs
alert ip $HOME_NET any -> [45.143.167.87,194.11.226.9,45.120.177.8,194.4.49.175,46.249.58.136] any (msg:"Bark&Bite - Iranian APT Cotton Sandstorm WezRat Known C2 IPs 2026"; classtype:command-and-control; sid:2000205; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

#==============================================================================
# SECTION 14: UNC1549 / NIMBUS MANTICORE FULL TOOLSET
# MITRE ATT&CK: T1574.001, T1572, T1003.006, T1113
# Group: UNC1549 (IRGC) — Aerospace/Defense/Telecom targeting
# Source: Mandiant/Google Frontline Intelligence; Check Point Research
#==============================================================================

# LIGHTRAIL - Obsolete Chrome/42 + Edge/12 UA combo (near-zero FP)
# SOCKS4a tunneler based on Lastenzug, WebSocket over HTTPS
alert http $HOME_NET any -> $EXTERNAL_NET 443 (msg:"Bark&Bite - Iranian APT UNC1549 LIGHTRAIL Obsolete UA 2025"; flow:to_server,established; content:"Chrome/42.0.2311.135"; http_user_agent; content:"Edge/12.10136"; http_user_agent; classtype:command-and-control; sid:2000206; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# LIGHTRAIL - WebSocket upgrade on /news URI to Azure
alert http $HOME_NET any -> $EXTERNAL_NET 443 (msg:"Bark&Bite - Iranian APT UNC1549 LIGHTRAIL WebSocket /news 2025"; flow:to_server,established; content:"/news"; http_uri; content:"Upgrade"; http_header; content:"websocket"; http_header; classtype:command-and-control; sid:2000207; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# POLLBLEND - Registration to Azure with computer name
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT UNC1549 POLLBLEND Register 2025"; flow:to_server,established; content:"POST"; http_method; content:"/register/"; http_uri; content:"username"; http_client_body; content:"azurewebsites.net"; http_host; classtype:command-and-control; sid:2000208; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# TWOSTROKE - C2 response separator @##@ in TCP stream
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT UNC1549 TWOSTROKE C2 Separator 2025"; flow:established,to_client; content:"@##@"; classtype:command-and-control; sid:2000209; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# DEEPROOT - C2 response separator -===- in TCP stream
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT UNC1549 DEEPROOT C2 Separator 2025"; flow:established,to_client; content:"-===-"; classtype:command-and-control; sid:2000210; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# MINIBIKE - /assets/<number>/ C2 beacon to Azure
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT UNC1549 MINIBIKE Assets C2 2025"; flow:to_server,established; content:"/assets/"; http_uri; content:"azurewebsites.net"; http_host; classtype:command-and-control; sid:2000211; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# GHOSTLINE - yamux multiplexing to Azure C2
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT UNC1549 GHOSTLINE Azure C2 Pattern 2025"; dns.query; pcre:"/^(ac-connection|active-az|skychain)[a-z0-9\-]+\.azurewebsites\.net$/i"; classtype:command-and-control; sid:2000212; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# UNC1549 - Career-portal phishing domains
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT UNC1549 Career Phishing Domain 2025"; dns.query; content:"careers"; nocase; pcre:"/(boeing-careers|rheinmetallcareer|flydubai-careers)\.(com|org|ae)$/i"; classtype:social-engineering; sid:2000213; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

#==============================================================================
# SECTION 15: HANDALA / VOID MANTICORE WIPER + STRYKER ATTACK
# MITRE ATT&CK: T1485, T1561.002, T1219, T1572, T1098
# Group: Void Manticore (MOIS) — Handala/Homeland Justice personas
# Source: Check Point Research "Handala Hack: Unveiling Group's MO" (2026)
#==============================================================================

# Handala - Known infrastructure IPs
alert ip $HOME_NET any -> [82.25.35.25,31.57.35.223,107.189.19.52] any (msg:"Bark&Bite - Iranian APT Handala Void Manticore Known C2 IP 2026"; classtype:command-and-control; sid:2000214; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

alert ip [82.25.35.25,31.57.35.223,107.189.19.52] any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT Handala Void Manticore Inbound C2 2026"; classtype:command-and-control; sid:2000215; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# Handala - VPN exit node used for operations
alert ip 146.185.219.235 any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT Handala VPN Exit Node 2026"; classtype:command-and-control; sid:2000216; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# Handala - Telegram bot token (exact match from Splunk analysis)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Handala Wiper Telegram C2 Token 2026"; flow:to_server,established; content:"api.telegram.org"; http_host; content:"6428401585:"; http_uri; classtype:command-and-control; sid:2000217; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# Handala - NetBird mesh networking tool (used for tunneling into isolated segments)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Handala NetBird Mesh Tunnel 2026"; flow:to_server,established; tls.sni; content:"netbird"; nocase; threshold:type both, track by_src, count 1, seconds 3600; classtype:policy-violation; sid:2000218; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# Handala - LSASS dump via rundll32 comsvcs.dll (specific technique)
# Network detection: large data transfer following this host indicator
# Primarily a Wazuh/endpoint rule; network correlation below
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Handala Post-Credential Exfil 2026"; flow:to_server,established; content:"POST"; http_method; content:"lsass"; http_client_body; nocase; classtype:credential-theft; sid:2000219; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

#==============================================================================
# SECTION 16: SICARII RAAS
# MITRE ATT&CK: T1486, T1561, T1003.001, T1021.001
# Group: Pro-Iranian/Handala-linked RaaS — operator @Skibcum
# Source: Check Point Research "Sicarii Ransomware: Truth vs Myth" (2026)
#==============================================================================

# Sicarii - Connectivity check burst (>10 requests to google.com/generate_204 in 30s)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Sicarii Connectivity Burst 2026"; flow:to_server,established; content:"GET"; http_method; content:"/generate_204"; http_uri; content:"google.com"; http_host; threshold:type both, track by_src, count 10, seconds 30; classtype:trojan-activity; sid:2000220; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# Sicarii - Data exfiltration to file.io
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Sicarii Exfil to file.io 2026"; flow:to_server,established; content:"POST"; http_method; content:"file.io"; http_host; classtype:trojan-activity; sid:2000221; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

