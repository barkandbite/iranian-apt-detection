#==============================================================================

# SloppyMIO - GitHub Gist dead-drop resolver (known account)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT RedKitten SloppyMIO GitHub Gist Dead-Drop 2026"; flow:to_server,established; content:"gist.githubusercontent.com"; http_host; content:"johnpeterson1304"; http_uri; classtype:command-and-control; sid:2000226; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

# SloppyMIO - Generic GitHub Gist access from non-browser (broader detection)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Generic GitHub Gist Dead-Drop Pattern 2026"; flow:to_server,established; content:"gist.githubusercontent.com"; http_host; content:!"Mozilla"; http_user_agent; threshold:type both, track by_src, count 3, seconds 7200; classtype:command-and-control; sid:2000227; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)

