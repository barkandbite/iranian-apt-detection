alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Infy Tonnerre Telegram Bot C2 2025"; flow:to_server,established; content:"api.telegram.org"; http_host; content:"ttestro1bot"; http_uri; nocase; classtype:command-and-control; sid:2000171; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

#==============================================================================
# SECTION 5: UNC1549 / NIMBUS MANTICORE AEROSPACE TARGETING
# MITRE ATT&CK: T1574.001, T1572, T1003.006
# Context: Mandiant-tracked surge hitting aerospace and defense via
#          third-party access; TWOSTROKE, DEEPROOT, and multiple toolsets
#==============================================================================

# --- TWOSTROKE / DEEPROOT (November 2025) ---
# TWOSTROKE: C++ backdoor with compromised code-signing certs
# DEEPROOT: Cross-platform Go backdoor (Linux/Windows)
# Both use Azure tenant accounts for C2 and SSH reverse tunnels
# Additional tools: CRASHPAD, DCSYNCER.SLICK, SIGHTGRAB, TRUSTTRAP,
#                   GHOSTLINE, POLLBLEND

# UNC1549 - SSH reverse tunnel on non-standard ports (C2 pattern)
# Iranian actors use SSH tunnels for persistence; detect SSH on unusual ports
alert tcp $HOME_NET any -> $EXTERNAL_NET !22 (msg:"Bark&Bite - Iranian APT UNC1549 SSH Reverse Tunnel Non-Standard Port 2025"; flow:to_server,established; content:"SSH-2.0-"; depth:8; threshold:type both, track by_src, count 1, seconds 3600; classtype:command-and-control; sid:2000172; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# UNC1549 - DCSync attack over DRSUAPI (DCSYNCER.SLICK tool)
# Detect non-DC hosts requesting DRS replication
# MITRE: T1003.006 (DCSync)
alert tcp $HOME_NET any -> $HOME_NET 135 (msg:"Bark&Bite - Iranian APT UNC1549 DCSYNCER SLICK DCSync Attempt 2025"; flow:to_server,established; content:"|05 00 0b|"; depth:3; content:"e3514235-4b06-11d1-ab04-00c04fc2dcd2"; nocase; distance:0; within:200; classtype:credential-theft; sid:2000173; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

#==============================================================================
# SECTION 6: REDKITTEN / CHARMING KITTEN / APT42 / CRAFTY CAMEL
# MITRE ATT&CK: T1102.001, T1027.003, T1566.001
# Context: Targeting human rights NGOs, activists, journalists, and GCC
#          aviation/critical infrastructure
#==============================================================================

# --- RedKitten SloppyMIO (January 2026) ---
# Three-stage C2: GitHub dead-drop -> steganographic config on Google Drive
#                 -> Telegram Bot API for commands
# Beacons every 2 hours via scheduled task
# AI-generated VBA macro code
# MITRE: T1102.001 (Dead Drop Resolver), T1027.003 (Steganography)

# SloppyMIO - GitHub raw content dead-drop resolver
# Detects systematic fetching of GitHub raw content that may contain
# encoded C2 addresses (non-browser user-agent to raw.githubusercontent.com)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT RedKitten SloppyMIO GitHub Dead-Drop 2026"; flow:to_server,established; content:"raw.githubusercontent.com"; http_host; content:!"Mozilla"; http_user_agent; threshold:type both, track by_src, count 3, seconds 7200; classtype:command-and-control; sid:2000174; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- BellaCiao / BellaCpp DNS Beaconing (Charming Kitten) ---
# DNS-based C2 with structured subdomain pattern:
# <5+ alpha chars><alphanum>.XX.systemupdate.info
# MITRE: T1071.004 (DNS)
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT Charming Kitten BellaCiao DNS Beacon 2026"; dns.query; content:".systemupdate.info"; nocase; endswith; classtype:domain-c2; sid:2000175; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- Crafty Camel (2025) ---
# Targets GCC aviation/infrastructure via compromised third-party emails
# Uses OneDrive/Dropbox for payload relay with polyglot files
# MITRE: T1566.001 (Spearphishing Attachment), T1027.009 (Embedded Payloads)

# Crafty Camel - Polyglot file download (HTA disguised as PDF)
# Detect .pdf.hta double extension downloads
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Crafty Camel Polyglot HTA Download 2025"; flow:to_server,established; content:"GET"; http_method; content:".pdf.hta"; http_uri; classtype:trojan-activity; sid:2000176; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

#==============================================================================
# SECTION 7: RANSOMWARE OPERATIONS
# MITRE ATT&CK: T1486, T1490, T1027.002
# Groups: Fox Kitten/Pioneer Kitten (Pay2Key.I2P), Cotton Sandstorm
# Context: Pay2Key.I2P first full RaaS on I2P network; 80% profit share
#          for attacks on "enemies of Iran"; $4M+ from 51+ attacks
#==============================================================================

# --- Pay2Key.I2P Ransomware (Feb 2025 resurgence) ---
# First full RaaS on I2P anonymous network (not Tor)
# Attack chain: 7-Zip SFX -> dual CMD/PS loaders -> XOR payloads ->
#               Themida-protected Mimic ransomware (ELENOR-Corp variant)
# MITRE: T1486, T1027.002 (Software Packing)

# Pay2Key - PowerShell creating Defender file-type exclusion for .exe
# Characteristic pre-encryption preparation step
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Pay2Key Defender Exclusion Setup 2025"; flow:to_server,established; content:"powershell"; nocase; http_client_body; content:"Add-MpPreference"; distance:0; within:200; content:"-ExclusionExtension"; distance:0; within:200; content:".exe"; distance:0; within:50; classtype:trojan-activity; sid:2000177; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# Pay2Key - I2P network traffic detection
# I2P uses UDP on high ports (typically 9000+) for transport
# Detects I2P router bootstrap connections
alert udp $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Pay2Key I2P Network Bootstrap 2025"; content:"I2P"; depth:10; threshold:type both, track by_src, count 5, seconds 300; classtype:policy-violation; sid:2000178; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# Pay2Key - 7-Zip SFX self-extracting archive with embedded executables
# Detect SFX archives being downloaded that match the attack chain
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Pay2Key 7zip SFX Payload Delivery 2025"; flow:to_client,established; content:"200"; http_stat_code; file_data; content:"7z"; depth:4; content:"!@Install@"; distance:0; within:100; classtype:trojan-activity; sid:2000179; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

#==============================================================================
# SECTION 8: CLOUD SERVICE ABUSE AND EVASION
# MITRE ATT&CK: T1567.002, T1102, T1090.004
# Context: Iranian actors weaponize Wasabi, Backblaze, Telegram, Ethereum
#          blockchain, Cloudflare tunneling to evade traditional detection
#==============================================================================

# --- Rclone-based Data Exfiltration ---
# MuddyWater uses Rclone for cloud exfil; detect Rclone user-agent
# MITRE: T1567.002 (Exfiltration to Cloud Storage)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater Rclone Exfil User-Agent 2026"; flow:to_server,established; content:"rclone/"; http_user_agent; classtype:trojan-activity; sid:2000180; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- Ethereum Blockchain C2 Resolution (EtherHiding) ---
# MuddyWater embeds C2 addresses in smart contracts
# Detect Ethereum JSON-RPC calls from enterprise endpoints
# MITRE: T1568.002 (Domain Generation Algorithms)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater EtherHiding Blockchain C2 2026"; flow:to_server,established; content:"POST"; http_method; content:"eth_call"; http_client_body; threshold:type both, track by_src, count 3, seconds 600; classtype:command-and-control; sid:2000181; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- Unauthorized RMM Tool Detection ---
# MuddyWater deploys AnyDesk (via HTTP_VIP), MeshCentral, SimpleHelp
# on compromised networks including OT-adjacent workstations
# MITRE: T1219 (Remote Access Software)

# AnyDesk - Relay traffic to AnyDesk infrastructure
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater AnyDesk RMM Abuse 2026"; flow:to_server,established; tls.sni; content:".net.anydesk.com"; endswith; threshold:type both, track by_src, count 1, seconds 3600; classtype:policy-violation; sid:2000182; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# MeshCentral - Agent check-in pattern
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater MeshCentral RMM Abuse 2026"; flow:to_server,established; tls.sni; content:"meshcentral"; nocase; threshold:type both, track by_src, count 1, seconds 3600; classtype:policy-violation; sid:2000183; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

#==============================================================================
# SECTION 9: BEHAVIORAL AND INFRASTRUCTURE PATTERNS
# MITRE ATT&CK: T1588.003, T1583.001, T1078
# Context: Cross-group behavioral indicators that help identify Iranian
#          operations regardless of specific malware family
#==============================================================================

# --- MuddyWater Fortinet Webshell Activity ---
# After initial access via FortiOS CVEs, MuddyWater drops webshells
# and modifies VPN configurations
# MITRE: T1505.003 (Web Shell)

# Fortinet webshell - POST to /remote/logincheck with webshell indicators
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT MuddyWater Fortinet Webshell Upload 2026"; flow:to_server,established; content:"POST"; http_method; content:"/remote/"; http_uri; content:"exec("; http_client_body; classtype:successful-admin; sid:2000184; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- MuddyWater FortiOS VPN Group Manipulation ---
# Modifying VPN user groups to maintain access after patching
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT MuddyWater FortiOS VPN Group Modify 2026"; flow:to_server,established; content:"PUT"; http_method; content:"/api/v2/cmdb/vpn.ssl/settings"; http_uri; classtype:attempted-admin; sid:2000185; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- Mass Credential Brute Force ---
# Per CISA AA24-290A: Iranian actors use MFA push bombing, password spraying
# Detect rapid authentication failures indicative of Iranian brute force
# MITRE: T1110.003 (Password Spraying), T1621 (MFA Request Generation)

# High-rate LDAP bind failures (password spray indicator)
alert tcp $EXTERNAL_NET any -> $HOME_NET 389 (msg:"Bark&Bite - Iranian APT Credential Spray LDAP Bind Flood 2026"; flow:to_server,established; content:"|30|"; depth:1; content:"|60|"; distance:0; within:10; threshold:type both, track by_src, count 30, seconds 60; classtype:credential-theft; sid:2000186; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- Default Credential Exploitation on IoT/OT ---
# CyberAv3ngers targets devices with factory-default credentials
# CISA AA23-335A: Unitronics PLCs left with default password "1111"
# MITRE: T1078.001 (Default Accounts)

# Unitronics default credential attempt
alert tcp $EXTERNAL_NET any -> $HOME_NET 20256 (msg:"Bark&Bite - Iranian APT CyberAv3ngers Unitronics Default Cred 2026"; flow:to_server,established; content:"1111"; classtype:attempted-admin; sid:2000187; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

#==============================================================================
# SECTION 10: MUDDYVIPER / FOODER AND ADDITIONAL TOOLS
# MITRE ATT&CK: T1059, T1105, T1071
# Context: Mid-2025 campaigns targeting Israel with potential Western expansion
#==============================================================================

# --- MuddyViper/Fooder (mid-2025) ---
# MuddyViper: C/C++ backdoor with CNG API encryption
# Fooder: Loader disguised as Snake video game
# Uses SSH reverse tunnels for C2 persistence
# MITRE: T1059.003, T1572

# MuddyViper - SSH reverse tunnel establishment (outbound SSH to high ports)
alert tcp $HOME_NET any -> $EXTERNAL_NET 2222:65535 (msg:"Bark&Bite - Iranian APT MuddyWater SSH Tunnel High Port 2025"; flow:to_server,established; content:"SSH-2.0-"; depth:8; threshold:type both, track by_src, count 1, seconds 3600; classtype:command-and-control; sid:2000188; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- WezRat (Cotton Sandstorm) ---
# Modular infostealer; commands, screenshots, keylogging, clipboard/cookie theft
# Communicates over HTTPS with structured JSON command/response
# MITRE: T1056.001 (Keylogging), T1113 (Screen Capture)

# WezRat - Characteristic Chrome cookie database exfiltration over HTTP
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Cotton Sandstorm WezRat Cookie Exfil 2026"; flow:to_server,established; content:"POST"; http_method; content:"Cookies"; http_client_body; content:"chrome"; distance:0; within:100; nocase; classtype:trojan-activity; sid:2000189; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

#==============================================================================
# SECTION 11: CORRELATION AND MULTI-STAGE DETECTION
# These rules fire when multiple indicators from earlier sections align,
# providing high-confidence composite alerts
#==============================================================================

# Multi-stage: FortiOS exploitation followed by Wasabi/Backblaze exfil
# Correlates initial access CVE with data exfiltration stage
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater FortiOS-to-Cloud Attack Chain 2026"; flow:to_server,established; flowbits:isset,iranian.fortios.saml; content:".wasabisys.com"; http_host; classtype:successful-admin; sid:2000190; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater FortiOS-to-Backblaze Attack Chain 2026"; flow:to_server,established; flowbits:isset,iranian.fortios.saml; content:".backblazeb2.com"; http_host; classtype:successful-admin; sid:2000191; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# Multi-stage: Ivanti EPMM exploit followed by Telegram C2
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater Ivanti-to-Telegram Attack Chain 2026"; flow:to_server,established; flowbits:isset,iranian.ivanti.epmm; content:"api.telegram.org"; http_host; classtype:successful-admin; sid:2000192; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# Multi-stage: ICS exploitation followed by IOCONTROL MQTT C2 setup
alert tcp $HOME_NET any -> $EXTERNAL_NET 8883 (msg:"Bark&Bite - Iranian APT CyberAv3ngers ICS Exploit-to-MQTT Chain 2026"; flow:to_server,established; flowbits:isset,iranian.fortios.admin; content:"|16 03|"; depth:2; classtype:successful-admin; sid:2000193; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

