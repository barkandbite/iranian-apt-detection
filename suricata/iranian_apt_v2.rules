# --- IOCONTROL Malware ---
# Custom OT/IoT cyberweapon; targets D-Link, Hikvision, Baicells, Red Lion,
# Orpak, Phoenix Contact, Teltonika, Unitronics
# C2: MQTT over TLS (port 8883), also cleartext (1883)
# Evasion: DNS-over-HTTPS via Cloudflare
# Config: AES-256-CBC encrypted
# Binary: /usr/bin/iocontrol
# Commands: "hello" (sysinfo), "check exec", "execute command", "self-delete",
#           "port scan"
# Initially 0/66 VirusTotal detections
# MITRE: T1071.005 (MQTT), T1573.002 (Asymmetric Cryptography)

# IOCONTROL - MQTT over TLS on port 8883 from OT/IoT segments
# This is the primary C2 channel; MQTT CONNECT packet starts with 0x10
alert tcp $HOME_NET any -> $EXTERNAL_NET 8883 (msg:"Bark&Bite - Iranian APT CyberAv3ngers IOCONTROL MQTT-TLS C2 2026"; flow:to_server,established; content:"|16 03|"; depth:2; threshold:type both, track by_src, count 3, seconds 600; classtype:command-and-control; sid:2000157; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# IOCONTROL - MQTT cleartext on port 1883 (CONNECT packet detection)
# MQTT fixed header: first byte 0x10 = CONNECT, followed by remaining length
alert tcp $HOME_NET any -> $EXTERNAL_NET 1883 (msg:"Bark&Bite - Iranian APT CyberAv3ngers IOCONTROL MQTT Cleartext C2 2026"; flow:to_server,established; content:"|10|"; offset:0; depth:1; content:"MQTT"; distance:0; within:12; classtype:command-and-control; sid:2000158; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# IOCONTROL - DNS-over-HTTPS via Cloudflare from non-browser process
# OT devices should NOT be making DoH requests to Cloudflare
# MITRE: T1071.004 (DNS), T1568.002 (Dynamic Resolution)
alert tls $HOME_NET any -> $EXTERNAL_NET 443 (msg:"Bark&Bite - Iranian APT CyberAv3ngers IOCONTROL DoH Cloudflare 2026"; flow:to_server,established; tls.sni; content:"cloudflare-dns.com"; classtype:command-and-control; sid:2000159; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# IOCONTROL - DNS-over-HTTPS query pattern (application/dns-message)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT IOCONTROL DoH Query Pattern 2026"; flow:to_server,established; content:"GET"; http_method; content:"/dns-query"; http_uri; content:"dns="; http_uri; classtype:command-and-control; sid:2000160; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_09;)

# --- PLC_Controller.exe (July 2025) ---
# Compiled Python tool sending S7comm/COTP requests to Siemens S7-300/S7-400
# Forces PLCs into STOP mode - direct ICS disruption capability
# S7comm over COTP on TCP port 102
# MITRE: T0831 (Manipulation of Control), T0855 (Unauthorized Command)

