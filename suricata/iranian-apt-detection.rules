alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT Self-Signed Cert Inbound Connection 2026"; flow:to_server,established; tls.cert_subject; content:"CN="; content:!"DigiCert"; content:!"Let's Encrypt"; content:!"Sectigo"; content:!"GeoTrust"; threshold:type both, track by_src, count 3, seconds 3600; classtype:bad-unknown; sid:2000298; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

# SSH on port 443 (Iranian actors disguise SSH tunnels as HTTPS)
alert tcp $HOME_NET any -> $EXTERNAL_NET 443 (msg:"Bark&Bite - Iranian APT SSH over Port 443 Evasion 2026"; flow:to_server,established; content:"SSH-2.0-"; depth:8; classtype:command-and-control; sid:2000299; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

# DNS-over-HTTPS to non-standard providers (Google DoH)
alert tls $HOME_NET any -> $EXTERNAL_NET 443 (msg:"Bark&Bite - Iranian APT DoH Google DNS Evasion 2026"; flow:to_server,established; tls.sni; content:"dns.google"; classtype:command-and-control; sid:2000300; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

