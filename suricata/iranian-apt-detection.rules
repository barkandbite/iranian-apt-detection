# TAMECAT - Firebase C2 from non-browser process
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT APT42 TAMECAT Firebase C2 2025"; flow:to_server,established; content:"firebaseio.com"; http_host; content:!"Mozilla"; http_user_agent; threshold:type both, track by_src, count 5, seconds 3600; classtype:command-and-control; sid:2000380; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
