#==============================================================================
# SECTION 39: HEALTHCARE EMERGENCY UPDATE - MARCH 25, 2026
# Three concurrent Iranian campaigns targeting U.S. healthcare:
#   1. Handala/Void Manticore Stryker wipe via Microsoft Intune
#   2. Pay2Key v3 ransomware vs unnamed U.S. healthcare org
#   3. MuddyWater CVE-2025-59287 WSUS exploitation
# Sources:
#   - Halcyon: Pay2Key v3 Technical Report (March 24, 2026)
#   - Centripetal: Pre-Positioned Access Brief (March 2026)
#   - CSA Labs: Handala/Stryker Research Note (March 2026)
#   - DOJ: Iranian Cyber Actor Attribution (March 20, 2026)
#   - The Record: Stryker Malware Confirmed (March 24, 2026)
#==============================================================================
# --- CVE-2025-59287: Windows WSUS Deserialization RCE (MuddyWater) ---
# Unauthenticated RCE via unsafe SoapFormatter deserialization
# CVSS 9.8; MuddyWater confirmed exploitation
# MITRE: T1190
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - HEALTHCARE Iranian APT CVE-2025-59287 WSUS Deserialization RCE 2026"; flow:to_server,established; content:"POST"; http_method; content:"/ReportingWebService/ReportingWebService.asmx"; http_uri; fast_pattern; reference:cve,2025-59287; classtype:attempted-admin; sid:2000405; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_25, updated_at 2026_03_25;)
# CVE-2025-59287 exploitation staging IPs
# IOC audit 2026-03-30: 185.69.24.18 attributed to Skuld Stealer (Darktrace), not MuddyWater;
# 194.68.32.90 unverifiable via OSINT; 45.84.107.17 malicious but MuddyWater link unconfirmed.
# All three remain on known-bad infrastructure — keeping rules active, downgraded to priority:2.
alert ip [194.68.32.90,45.84.107.17,185.69.24.18] any -> $HOME_NET any (msg:"Bark&Bite - HEALTHCARE CVE-2025-59287 WSUS Exploit Staging IPs 2026"; classtype:command-and-control; sid:2000406; rev:2; priority:2; metadata:policy max-detect-ips drop, created_at 2026_03_25, updated_at 2026_03_30;)
alert ip $HOME_NET any -> [194.68.32.90,45.84.107.17,185.69.24.18] any (msg:"Bark&Bite - HEALTHCARE CVE-2025-59287 WSUS Staging Outbound 2026"; classtype:command-and-control; sid:2000407; rev:2; priority:2; metadata:policy max-detect-ips drop, created_at 2026_03_25, updated_at 2026_03_30;)
# --- Microsoft Intune MDM Abuse (Handala Stryker-style wipe) ---
# Detect bulk device wipe commands via Microsoft Graph API
# MITRE: T1485
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - HEALTHCARE Iranian APT Handala Intune Mass Wipe API 2026"; flow:to_server,established; content:"POST"; http_method; content:"graph.microsoft.com"; http_host; content:"/deviceManagement/"; http_uri; content:"/wipe"; http_uri; classtype:attempted-dos; sid:2000408; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_25, updated_at 2026_03_25;)
# --- Pay2Key v3 Ransomware (IRGC / Fox Kitten) ---
# ChaCha20 + Curve25519 encryption; I2P C2; fake Avast AV bypass
# File extension: .6zldh_p2k; Ransom note: HowToRestoreFiles.txt
# MITRE: T1486, T1562.001, T1490
# Pay2Key v3 - I2P network bootstrap (UDP high ports)
# I2P uses NTCP2/SSU2 on random high UDP ports
alert udp $HOME_NET any -> $EXTERNAL_NET 9000:65535 (msg:"Bark&Bite - HEALTHCARE Iranian APT Pay2Key I2P SSU2 Bootstrap 2026"; dsize:>200; content:"|00 00 00 00|"; offset:0; depth:4; threshold:type both, track by_src, count 10, seconds 120; classtype:policy-violation; sid:2000409; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_25, updated_at 2026_03_25;)
# Pay2Key v3 - Pre-encryption: BitLocker suspension via PowerShell
# Detects PowerShell Suspend-BitLocker in HTTP traffic (lateral/C2 context)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - HEALTHCARE Iranian APT Pay2Key BitLocker Suspend 2026"; flow:to_server,established; content:"Suspend-BitLocker"; http_client_body; nocase; classtype:trojan-activity; sid:2000410; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_25, updated_at 2026_03_25;)
