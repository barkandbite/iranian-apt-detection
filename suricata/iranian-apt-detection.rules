#==============================================================================
# SECTION 41: HIGH-ENTROPY DNS AND DGA DETECTION
# MITRE ATT&CK: T1568.002
# Context: SOCRadar 2026 - OilRig/APT34 known for high-entropy subdomain
#          DNS queries; multiple Iranian groups use DGA
#==============================================================================

# OilRig-style high-entropy subdomain DNS queries
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT OilRig High-Entropy DNS Query 2026"; dns.query; pcre:"/^[a-z0-9]{20,}\.[a-z0-9-]+\.[a-z]{2,6}$/"; threshold:type both, track by_src, count 10, seconds 300; classtype:domain-c2; sid:2000318; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

# Iranian DGA - Random alphanumeric domain on .site TLD (Foudre pattern)
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT DGA .site TLD Resolution 2026"; dns.query; content:".site"; endswith; pcre:"/^[a-z0-9]{10,14}\.site$/"; threshold:type both, track by_src, count 5, seconds 600; classtype:domain-c2; sid:2000319; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

