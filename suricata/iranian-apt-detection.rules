# ============================================================================
# SECTION: March 2026 Expansion Port (from iranian-apt-detection v3_3_expansion)
# Ported: 2026-03-28
# Source: barkandbite/iranian-apt-detection suricata/iranian_apt_v3_3_expansion.rules
# Coverage: WSUS/CVE-2025-59287, WINTAPIX/UNC1860, Operation Olalampo IOCs,
#           Healthcare emergency (Intune wipe, Pay2Key I2P/BitLocker),
#           PCOM/ICS protocols, APT42 TAMECAT, Infy Tornado blockchain DGA,
#           FortiOS/Ivanti exploitation chains, xbits correlation
# SID Range: 2000360-2000419
# ============================================================================

# IOCONTROL - RabbitMQ management port 15672 (C2 management interface)
alert tcp $HOME_NET any -> $EXTERNAL_NET 15672 (msg:"Bark&Bite - Iranian APT CyberAv3ngers IOCONTROL RabbitMQ Mgmt 2026"; flow:to_server,established; classtype:command-and-control; sid:2000360; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# IOCONTROL - DoH to 1.1.1.1 with application/dns-json (OT anomaly)
# IOCONTROL uses GET with accept: application/dns-json, not standard dns-message
alert http $HOME_NET any -> 1.1.1.1 any (msg:"Bark&Bite - Iranian APT IOCONTROL DoH JSON Query 2026"; flow:to_server,established; content:"GET"; http_method; content:"/dns-query"; http_uri; content:"application/dns-json"; http_header; classtype:command-and-control; sid:2000361; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
#==============================================================================
# SECTION 20: UNITRONICS PCOM PROTOCOL EXPLOITATION
# MITRE ATT&CK: T0855, T0831, T1078.001
# Group: CyberAv3ngers
# Source: Claroty PCOM-Tools, CISA AA23-335A
#==============================================================================
# PCOM - Get PLC Name fingerprint (opcode 0x0C after /_OPLC magic)
# Magic bytes: 2F 5F 4F 50 4C 43 = "/_OPLC"
alert tcp $EXTERNAL_NET any -> $HOME_NET 20256 (msg:"Bark&Bite - Iranian APT CyberAv3ngers PCOM PLC Fingerprint 2026"; flow:to_server,established; content:"|2F 5F 4F 50 4C 43|"; depth:6; classtype:attempted-recon; sid:2000362; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# PCOM - Write Memory opcode 0x41 (malicious project upload)
alert tcp $EXTERNAL_NET any -> $HOME_NET 20256 (msg:"Bark&Bite - Iranian APT CyberAv3ngers PCOM Write Memory 2026"; flow:to_server,established; content:"|2F 5F 4F 50 4C 43|"; depth:6; content:"|41|"; offset:8; depth:1; classtype:attempted-admin; sid:2000363; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# PCOM - Reset Upload Password opcode 0x42 (CVE-2024-38434)
alert tcp $EXTERNAL_NET any -> $HOME_NET 20256 (msg:"Bark&Bite - Iranian APT CyberAv3ngers PCOM Password Reset CVE-2024-38434 2026"; flow:to_server,established; content:"|2F 5F 4F 50 4C 43|"; depth:6; content:"|42|"; offset:8; depth:1; reference:cve,2024-38434; classtype:attempted-admin; sid:2000364; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
#==============================================================================
# SECTION 21: CAMERA EXPLOITATION FOR BDA
# MITRE ATT&CK: T1190, T1595, T1040
# Group: CyberAv3ngers, Multiple Iranian actors
# Source: Check Point Research, VulnCheck
#==============================================================================
# Hikvision - NFS mount evasion (novel technique - portmapper contact)
# Instead of curl/wget, actors use mount to NFS-attach attacker server
alert tcp $HOME_NET any -> $EXTERNAL_NET 111 (msg:"Bark&Bite - Iranian APT Camera NFS Portmapper Evasion 2026"; flow:to_server,established; classtype:attempted-recon; sid:2000365; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# Dahua CVE-2025-31701 - RCE via Cseq header overflow
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT CyberAv3ngers Dahua CVE-2025-31701 RCE 2026"; flow:to_server,established; content:"POST"; http_method; content:"/RPC2_UploadFileWithName/"; http_uri; reference:cve,2025-31701; classtype:attempted-admin; sid:2000366; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
#==============================================================================
# SECTION 22: INDUSTRIAL PROTOCOL ABUSE
# MITRE ATT&CK: T0831, T0855, T0886
# Context: FBI/CISA confirmed Iranian targeting of hospital HVAC, water
#          systems, and building automation via industrial protocols
#==============================================================================
# BACnet Write-Property (UDP 47808) - Hospital HVAC/BAS targeting
# Service choice 0x0F = Write-Property; no authentication in standard BACnet
alert udp $EXTERNAL_NET any -> $HOME_NET 47808 (msg:"Bark&Bite - Iranian APT BACnet Write-Property Building Automation 2026"; content:"|0F|"; offset:7; depth:1; classtype:attempted-admin; sid:2000367; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# Modbus Write Single Register (FC6) from external source
# Function code 0x06 at offset 7 in Modbus TCP frame
alert tcp $EXTERNAL_NET any -> $HOME_NET 502 (msg:"Bark&Bite - Iranian APT Modbus Write Single Register from External 2026"; flow:to_server,established; content:"|00 00|"; depth:2; content:"|06|"; offset:7; depth:1; classtype:attempted-admin; sid:2000368; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# Modbus Write Multiple Registers (FC16) from external source
alert tcp $EXTERNAL_NET any -> $HOME_NET 502 (msg:"Bark&Bite - Iranian APT Modbus Write Multiple Registers from External 2026"; flow:to_server,established; content:"|00 00|"; depth:2; content:"|10|"; offset:7; depth:1; classtype:attempted-admin; sid:2000369; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# S7comm PLC STOP - Enhanced with P_PROGRAM stop string and TSAP detection
# S7-300 dest TSAP: 01 02 (slot 2); S7-400: 01 03 (slot 3)
alert tcp $HOME_NET any -> $HOME_NET 102 (msg:"Bark&Bite - Iranian APT S7comm P_PROGRAM STOP Enhanced 2026"; flow:to_server,established; content:"|03 00|"; depth:2; content:"P_PROGRAM"; classtype:attempted-admin; sid:2000370; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
