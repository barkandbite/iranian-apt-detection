alert ip $HOME_NET any -> [162.0.230.185,209.74.87.100,143.198.5.41,209.74.87.67] any (msg:"Bark&Bite - Iranian APT MuddyWater Olalampo C2 IPs 2026"; classtype:command-and-control; sid:2000375; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# MuddyWater - Service name MicrosoftVersionUpdater (persistence)
# Network correlation: detect DNS/HTTP from hosts where this service exists
# Primarily a Wazuh/endpoint detection
#==============================================================================
# SECTION 24: APT34 / OILRIG VEATY AND SPEARAL
# MITRE ATT&CK: T1071.004, T1071.003, T1132.001
# Group: APT34 / OilRig / Hazel Sandstorm (MOIS) — Iraq campaign
# Source: Check Point Research "Iranian Malware Attacks Iraqi Government"
#==============================================================================
# Spearal - Custom Base32 DNS tunneling subdomain pattern
# Spearal encodes data in DNS subdomains using custom Base32 alphabet
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT APT34 Spearal DNS Tunnel Pattern 2025"; dns.query; pcre:"/^[a-z2-7]{20,}\.[a-z2-7]{20,}\./i"; threshold:type both, track by_src, count 10, seconds 300; classtype:command-and-control; sid:2000376; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
