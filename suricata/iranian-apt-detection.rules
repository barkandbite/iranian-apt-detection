# SECTION: Boggy Serpens (MuddyWater) — BlackBeard & Nuso Backdoors
# Source: Unit 42 Threat Assessment (March 2026)
# Campaign: 4-wave attack Aug 2025 – Feb 2026 against UAE marine/energy
# MITRE: T1071.001, T1573.001, T1566.001, T1199
#==============================================================================

# BlackBeard Rust backdoor — HTTP status-code-driven C2 tasking
# BlackBeard uses standard HTTP status codes (200/204/403) for tasking and
# embeds C2 data in HTTP response headers. Non-browser UA from Rust runtime
# with small response bodies and header-embedded payloads.
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Boggy Serpens BlackBeard Rust C2 Beacon 2026"; flow:to_server,established; content:"GET"; http.method; http.user_agent; content:!"Mozilla"; content:!"Chrome"; content:!"Safari"; content:!"Edge"; content:!"Opera"; content:!"curl"; content:!"python"; content:!"Go-http"; urilen:<15; threshold:type both, track by_src, count 10, seconds 600; classtype:command-and-control; sid:2000462; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_30, updated_at 2026_03_30;)

# BlackBeard — C2 data exfiltration via custom HTTP headers
# BlackBeard embeds stolen data in HTTP request headers (non-standard header names)
# with small or empty request bodies
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Boggy Serpens BlackBeard Header Exfil 2026"; flow:to_server,established; content:"POST"; http.method; http.content_type; content:!"multipart"; content:!"json"; content:!"xml"; content:!"form-urlencoded"; http.user_agent; content:!"Mozilla"; urilen:<10; threshold:type both, track by_src, count 5, seconds 300; classtype:trojan-activity; sid:2000463; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_30, updated_at 2026_03_30;)

# Nuso HTTP backdoor — delivered via blurred document lures, beacons to C2
# Nuso uses novaservice.exe as the file path (shared with UDPGangster pipeline)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Boggy Serpens Nuso HTTP Backdoor UA 2026"; flow:to_server,established; http.user_agent; content:"novaservice"; nocase; classtype:command-and-control; sid:2000464; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_30, updated_at 2026_03_30;)

# Boggy Serpens Phoenix Lineage — VBA builder payload delivery
# Both Phoenix and UDPGangster tracks use identical decryption key and novaservice.exe path
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT Boggy Serpens Phoenix VBA Macro Document Delivery 2026"; flow:to_client,established; content:"application/msword"; http.content_type; file_data; content:"novaservice"; nocase; classtype:trojan-activity; sid:2000465; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_30, updated_at 2026_03_30;)

# Boggy Serpens — compromised diplomatic email relay detection
# Pattern: legitimate government domain as sender with engineering/diplomatic lure
# targeting embassies. Detects outbound email to multiple recipients with
# "Sustainable Peace" or subsea/pipeline themed subjects from HOME_NET
alert smtp $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Boggy Serpens Diplomatic Phish Lure 2026"; flow:to_server,established; content:"Subject|3a|"; content:"Sustainable Peace"; nocase; distance:0; within:200; classtype:social-engineering; sid:2000466; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_30, updated_at 2026_03_30;)

#==============================================================================
# SECTION: DUST SPECTER (Iran-nexus) — TwinTalk/TwinTask/SPLITDROP/GhostForm
# Ref: Zscaler ThreatLabz March 2026 — Dust Specter targets Iraqi officials
# Ref: Trellix "The Iranian Cyber Capability 2026"
# MITRE: T1071.001, T1132.001, T1574.002, T1001.003
#==============================================================================

# Dust Specter TwinTalk C2 — JWT Bearer token beacon with randomized hex URI
# TwinTalk uses HTTPS GET with Authorization: Bearer <JWT> header where the
# JWT is HS256-signed with a single underscore ('_') as the secret. URI paths
# are 10-char hex strings followed by a 6-char checksum seeded with 0xABCDEF.
# Detection: outbound HTTPS GET with JWT Authorization header to non-standard
# URI paths matching hex pattern. Low FP due to unusual URI + JWT combination.
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Dust Specter TwinTalk JWT C2 Beacon 2026"; flow:to_server,established; content:"GET"; http.method; http.header; content:"Authorization|3a| Bearer eyJ"; fast_pattern; http.uri; pcre:"/^\/[0-9a-f]{10,20}$/"; threshold:type both, track by_src, count 3, seconds 600; reference:url,zscaler.com/blogs/security-research/dust-specter-apt-targets-government-officials-iraq; classtype:command-and-control; sid:2000468; rev:1; metadata:policy max-detect-ips drop, created_at 2026_04_05, updated_at 2026_04_05;)

# Dust Specter C2 domain IOC — DNS resolution for known TwinTalk/SPLITDROP C2
# Domains: lecturegenieltd.pro, meetingapp.site, afterworld.store,
#          girlsbags.shop, onlinepettools.shop, web14.info, web27.info
