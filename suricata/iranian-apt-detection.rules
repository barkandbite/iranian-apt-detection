# CVE-2026-1281: Ivanti EPMM Unauthenticated RCE via bash arithmetic expansion
# Exploited by MuddyWater; CISA KEV Jan 29, 2026; scanned with Nuclei templates
# CVSS 9.8 - Targets /mifs/rs/api/v2/ endpoint with crafted arithmetic payloads
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT MuddyWater CVE-2026-1281 Ivanti EPMM RCE 2026"; flow:to_server,established; content:"POST"; http_method; content:"/mifs/rs/api/v2/"; http_uri; fast_pattern; content:"$((" ; http_client_body; flowbits:set,iranian.ivanti.epmm; reference:cve,2026-1281; classtype:attempted-admin; sid:2000131; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_09, updated_at 2026_03_12;)

