alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT Dust Specter TwinTalk C2 Domain DNS 2026"; dns.query; content:"meetingapp.site"; nocase; reference:url,zscaler.com/blogs/security-research/dust-specter-apt-targets-government-officials-iraq; classtype:command-and-control; sid:2000470; rev:1; metadata:policy max-detect-ips drop, created_at 2026_04_05, updated_at 2026_04_05;)

alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT Dust Specter TwinTalk C2 Domain DNS 2026"; dns.query; content:"afterworld.store"; nocase; reference:url,zscaler.com/blogs/security-research/dust-specter-apt-targets-government-officials-iraq; classtype:command-and-control; sid:2000471; rev:1; metadata:policy max-detect-ips drop, created_at 2026_04_05, updated_at 2026_04_05;)

