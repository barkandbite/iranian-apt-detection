#==============================================================================
# SECTION 31: MULTI-STAGE CORRELATION (XBITS - CROSS-FLOW)
# These rules use xbits instead of flowbits to correlate across connections
#==============================================================================
# Set xbits on FortiOS exploitation (replaces broken flowbits in SID 2000387-2000134)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT FortiOS Exploit xbit Set 2026"; flow:to_server,established; content:"POST"; http_method; content:"/api/v2/"; http_uri; content:"super_admin"; http_client_body; xbits:set,iranian.fortios.exploit,track ip_dst,expire 7200; classtype:attempted-admin; sid:2000387; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# Set xbits on Ivanti EPMM exploitation
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT Ivanti EPMM Exploit xbit Set 2026"; flow:to_server,established; content:"POST"; http_method; content:"/mifs/rs/api/v2/"; http_uri; content:"$(("; http_client_body; xbits:set,iranian.ivanti.exploit,track ip_dst,expire 7200; classtype:attempted-admin; sid:2000388; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
# Correlation: FortiOS exploit THEN Wasabi exfil (xbits cross-flow)
