alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT Infy Tornado Blockchain DGA eth_getStorageAt 2026"; flow:to_server,established; content:"POST"; http_method; content:"eth_getStorageAt"; http_client_body; classtype:command-and-control; sid:2000381; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_24, updated_at 2026_03_24;)
