# MITRE ATT&CK: T0883, T0885, T1219, T1565
# Group: CyberAv3ngers / Shahid Kaveh / Storm-0784 / UNC5691 (IRGC)
# Source: CISA AA26-097A (April 7, 2026), FBI FLASH
# Campaign: Active since March 2026 targeting Rockwell CompactLogix/Micro850
#   PLCs across US Water/Wastewater, Energy, and Government sectors via
#   CVE-2021-22681 auth bypass. Dropbear SSH for persistence.
# Note: Deploy on OT-adjacent segments ONLY. These rules target EtherNet/IP
#   CIP protocol traffic that is normal on OT networks — restrict to segments
#   where external-to-PLC traffic is anomalous.
#==============================================================================

# CIP RegisterSession from external — EtherNet/IP session registration
# CIP command 0x0065 (RegisterSession) on port 44818 from EXTERNAL_NET
# initiates a legitimate CIP session with a PLC. External sources should
# never directly register sessions with PLCs in a properly segmented network.
alert tcp $EXTERNAL_NET any -> $HOME_NET 44818 (msg:"Bark&Bite - Iranian APT CyberAv3ngers Rockwell CIP RegisterSession External 2026"; flow:to_server,established; content:"|65 00|"; depth:2; content:"|01 00 00 00|"; offset:4; depth:4; threshold:type both, track by_src, count 3, seconds 60; reference:cve,2021-22681; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-admin; sid:2000478; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_09, updated_at 2026_04_09;)

# CIP ListIdentity from external — EtherNet/IP device enumeration
# CIP command 0x0063 (ListIdentity) is a broadcast/unicast discovery command
# that returns PLC model, firmware version, and serial number. Adversaries
# use this to fingerprint Rockwell devices before exploitation.
alert tcp $EXTERNAL_NET any -> $HOME_NET 44818 (msg:"Bark&Bite - Iranian APT CyberAv3ngers Rockwell CIP ListIdentity Recon 2026"; flow:to_server,established; content:"|63 00|"; depth:2; threshold:type both, track by_src, count 3, seconds 60; reference:cve,2021-22681; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-recon; sid:2000479; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_09, updated_at 2026_04_09;)

# CIP ForwardOpen from external — CIP connection establishment
# CIP command 0x0054 (ForwardOpen) within an encapsulated SendRRData or
# SendUnitData (0x006F) opens a Class 3 connection to a PLC program.
# This is the precursor to reading/writing PLC project files (ACD).
# External ForwardOpen to an internal PLC is a critical indicator.
alert tcp $EXTERNAL_NET any -> $HOME_NET 44818 (msg:"Bark&Bite - Iranian APT CyberAv3ngers Rockwell CIP ForwardOpen Connection 2026"; flow:to_server,established; content:"|6f 00|"; depth:2; content:"|54|"; distance:20; within:30; threshold:type both, track by_src, count 2, seconds 60; reference:cve,2021-22681; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-admin; sid:2000480; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_09, updated_at 2026_04_09;)

# CIP SendRRData from external — encapsulated CIP service requests
# CIP command 0x006F (SendRRData) carries CIP service messages for reading
# project files, uploading firmware, or modifying PLC logic. Any external
# source sending encapsulated CIP data to internal PLCs is suspicious.
alert tcp $EXTERNAL_NET any -> $HOME_NET 44818 (msg:"Bark&Bite - Iranian APT CyberAv3ngers Rockwell CIP SendRRData to PLC 2026"; flow:to_server,established; content:"|6f 00|"; depth:2; threshold:type both, track by_src, count 5, seconds 60; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-admin; sid:2000481; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_09, updated_at 2026_04_09;)

# Dropbear SSH on OT ports — lightweight SSH server for PLC persistence
# CyberAv3ngers install Dropbear SSH on compromised PLCs for persistent
# remote access. Detect SSH handshake (SSH-2.0-dropbear) on OT-associated
# ports (44818, 2222, 102, 502, 20256). Legitimate PLCs do not run Dropbear.
alert tcp $HOME_NET [44818,2222,102,502,20256] -> any any (msg:"Bark&Bite - Iranian APT CyberAv3ngers Dropbear SSH on OT Port Persistence 2026"; flow:to_client,established; content:"SSH-2.0-dropbear"; depth:20; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:trojan-activity; sid:2000482; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_09, updated_at 2026_04_09;)

# Rockwell Studio 5000 project file download — ACD file exfiltration
# CyberAv3ngers extract .ACD project files containing ladder logic and
# configuration blueprints. Detect outbound transfer of ACD file headers
# from OT segments to external destinations.
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT CyberAv3ngers Rockwell ACD Project File Exfil 2026"; flow:to_server,established; content:"|52 53 4C 6F 67 35|"; depth:10; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:bad-unknown; sid:2000483; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_09, updated_at 2026_04_09;)

# CIP ListIdentity UDP broadcast — EtherNet/IP device discovery scan
# CIP ListIdentity (0x0063) sent via UDP/44818 is used for broadcast
# device enumeration. External UDP scans for industrial devices are
# a hallmark of CyberAv3ngers reconnaissance.
alert udp $EXTERNAL_NET any -> $HOME_NET 44818 (msg:"Bark&Bite - Iranian APT CyberAv3ngers EtherNet-IP UDP ListIdentity Scan 2026"; content:"|63 00|"; depth:2; threshold:type both, track by_src, count 3, seconds 60; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-recon; sid:2000484; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_09, updated_at 2026_04_09;)

# SSH connection to OT port range from external — any SSH on PLC ports
# Regardless of SSH implementation, SSH connections to known PLC service
# ports from external sources indicate unauthorized access or persistence.
alert tcp $EXTERNAL_NET any -> $HOME_NET [44818,2222,102,502,20256] (msg:"Bark&Bite - Iranian APT CyberAv3ngers SSH to OT Port External Access 2026"; flow:to_server,established; content:"SSH-"; depth:4; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-admin; sid:2000485; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_09, updated_at 2026_04_09;)

#################################################################################
# SECTION: MuddyWater ChainShell / CastleRAT — Russian MaaS Campaign (April 2026)
# Source: JUMPSEC, CybersecurityNews, Ctrl-Alt-Intel (Mar-Apr 2026)
# MuddyWater adopted TAG-150's CastleRAT Russian MaaS platform, deploying
# ChainShell (Node.js agent) that resolves C2 from Ethereum smart contracts.
# Targets Israeli government and infrastructure. C2 infrastructure includes
# serialmenot.com domain shared across deployments and JWT tokens with
# "Smokest" campaign ID. ChainShell delivered via reset.ps1 PowerShell deployer.
# MITRE: T1059.007 (JavaScript), T1102.002 (Bidirectional Communication),
#        T1573.002 (Asymmetric Cryptography), T1071.001 (Web Protocols)
#################################################################################

# MuddyWater ChainShell C2 DNS — serialmenot.com
# Shared C2 domain used across ChainShell/CastleRAT deployments. Per-operation
# JWT credentials separate access and tracking, but the domain is consistent.
# JUMPSEC confirmed active use against Israeli targets in March 2026.
alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT MuddyWater ChainShell C2 DNS serialmenot.com 2026"; flow:to_server; dns.query; content:"serialmenot.com"; nocase; fast_pattern; reference:url,jumpsec.com/guides/chainshell-muddywater-russian-criminal-infrastructure; classtype:command-and-control; sid:2000491; rev:1; metadata:policy max-detect-ips drop, created_at 2026_04_11, updated_at 2026_04_11;)

# MuddyWater ChainShell CastleRAT HTTP beacon — "Smokest" campaign JWT
# CastleRAT builds use JWT tokens containing the "Smokest" campaign identifier
# and userID bb47c0615477a877. These appear in HTTP Authorization headers or
# POST bodies during C2 check-in. The campaign ID is unique to MuddyWater's
# TAG-150 MaaS subscription.
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater CastleRAT Smokest Campaign JWT Beacon 2026"; flow:to_server,established; http.method; content:"POST"; http.request_body; content:"Smokest"; fast_pattern; content:"bb47c0615477a877"; distance:0; within:200; reference:url,jumpsec.com/guides/chainshell-muddywater-russian-criminal-infrastructure; classtype:command-and-control; sid:2000492; rev:1; metadata:policy max-detect-ips drop, created_at 2026_04_11, updated_at 2026_04_11;)

# MuddyWater ChainShell — Node.js HTTP POST to serialmenot.com
# ChainShell is a Node.js agent; outbound HTTP from Node.js runtime to the
# known C2 domain is a high-confidence indicator. Behavioral complement to
# the DNS rule above.
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Bark&Bite - Iranian APT MuddyWater ChainShell Node.js HTTP C2 serialmenot.com 2026"; flow:to_server,established; http.host; content:"serialmenot.com"; fast_pattern; http.user_agent; content:"node"; nocase; reference:url,cybersecuritynews.com/muddywater-turns-to-russian-malware-as-a-service; classtype:command-and-control; sid:2000493; rev:1; metadata:policy max-detect-ips drop, created_at 2026_04_11, updated_at 2026_04_11;)

# ================================================================================
# SECTION: MuddyWater Fooder/MuddyViper C2 IOC Update (April 2026)
# Source: Trellix "The Iranian Cyber Capability 2026" (April 2026)
# Attribution: MuddyWater (MOIS / Mango Sandstorm / Seedworm)
# Context: MuddyWater observed active in networks of US airport, bank, and
#   Israel-linked software firm. Deploying Fooder loader to execute MuddyViper
#   backdoor. Heavy use of legitimate RMM tools (Atera, AnyDesk, Syncro,
#   SimpleHelp, NetBird) for persistence. Two new C2 IPs identified.
# MITRE: T1071.001 (Web Protocols), T1573.002 (Asymmetric Cryptography),
#   T1090 (Proxy), T1219 (Remote Access Software)
# ================================================================================

# MuddyWater Fooder/MuddyViper C2 IP 206.71.149.51 — HTTPS on port 443
# Trellix identified this IP as active MuddyWater C2 serving Fooder loader
# payloads and receiving MuddyViper beacon check-ins over HTTPS.
alert tls $HOME_NET any -> 206.71.149.51 443 (msg:"Bark&Bite - Iranian APT MuddyWater Fooder/MuddyViper C2 206.71.149.51 2026"; flow:to_server,established; reference:url,trellix.com/blogs/research/the-iranian-cyber-capability-2026; classtype:command-and-control; sid:2000494; rev:1; metadata:policy max-detect-ips drop, created_at 2026_04_15, updated_at 2026_04_15;)

# MuddyWater C2 IP 104.238.191.185 — SSH tunneled over port 443
# Trellix observed MuddyWater tunneling SSH over port 443 to this IP for
# interactive shell access and lateral movement coordination. SSH on 443
# is a common MuddyWater evasion technique to bypass firewall rules.
alert ssh $HOME_NET any -> 104.238.191.185 443 (msg:"Bark&Bite - Iranian APT MuddyWater SSH-over-443 C2 104.238.191.185 2026"; flow:to_server,established; reference:url,trellix.com/blogs/research/the-iranian-cyber-capability-2026; classtype:command-and-control; sid:2000495; rev:1; metadata:policy max-detect-ips drop, created_at 2026_04_15, updated_at 2026_04_15;)

# ================================================================================
# SECTION: CyberAv3ngers EtherNet/IP and ICS Protocol Behavioral Detection
# Source: CISA Advisory AA26-097A (April 7, 2026)
# Attribution: CyberAv3ngers (IRGC-CEC / Shahid Kaveh Group / Storm-0784 /
#   Bauxite / UNC5691 / Hydro Kitten)
# Context: Behavioral signatures that survive infrastructure rotation. Detect
#   unauthorized EtherNet/IP, Modbus, and SSH access to ICS/OT segments
#   regardless of source IP. Complements IOC rules in cyberav3ngers-ioc-aa26-097a.rules.
# DEPLOY NOTE: Priority:1 ICS/OT rules. Enable ONLY on OT-adjacent segments.
#   These rules will fire on legitimate engineering workstation traffic if
#   deployed on IT segments — tune $HOME_NET to ICS/SCADA subnets only.
# MITRE: T0883, T0885, T1219, T0855 (Unauthorized Command Message)
# ================================================================================

# External EtherNet/IP to internal PLCs on port 44818
alert tcp $EXTERNAL_NET any -> $HOME_NET 44818 (msg:"Bark&Bite - Iranian CyberAv3ngers External EtherNet/IP to PLC Port 44818 2026"; flow:to_server; threshold:type limit, track by_src, count 1, seconds 300; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-admin; sid:2000498; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_18, updated_at 2026_04_18;)

# External SSH on alt port 2222 to ICS segments (Dropbear SSH)
alert tcp $EXTERNAL_NET any -> $HOME_NET 2222 (msg:"Bark&Bite - Iranian CyberAv3ngers Dropbear SSH Alt Port 2222 to ICS 2026"; flow:to_server,established; content:"SSH-"; depth:4; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-admin; sid:2000499; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_18, updated_at 2026_04_18;)

# External Modbus TCP to internal OT on port 502
alert tcp $EXTERNAL_NET any -> $HOME_NET 502 (msg:"Bark&Bite - Iranian CyberAv3ngers External Modbus TCP to OT Port 502 2026"; flow:to_server; threshold:type limit, track by_src, count 1, seconds 300; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-admin; sid:2000500; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_18, updated_at 2026_04_18;)

# External S7comm/ISO-TSAP to internal OT on port 102
alert tcp $EXTERNAL_NET any -> $HOME_NET 102 (msg:"Bark&Bite - Iranian CyberAv3ngers External S7comm ISO-TSAP to OT Port 102 2026"; flow:to_server; threshold:type limit, track by_src, count 1, seconds 300; reference:url,cisa.gov/news-events/cybersecurity-advisories/aa26-097a; classtype:attempted-admin; sid:2000501; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_04_18, updated_at 2026_04_18;)
