alert dns $HOME_NET any -> any any (msg:"Bark&Bite - Iranian APT High-Entropy Ephemeral Domain C2"; dns.query; pcre:"/^[a-z0-9]{12,20}\.(site|online|ix\.tc|cc|sr)$/i"; classtype:domain-c2; sid:2000356; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

# Self-signed cert C2
alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT Self-Signed Cert C2 Inbound"; flow:to_server,established; tls.cert_subject; content:"self signed"; nocase; classtype:trojan-activity; sid:2000357; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

# SSH over 443
alert tcp $HOME_NET any -> $EXTERNAL_NET 443 (msg:"Bark&Bite - Iranian APT SSH over Port 443 Evasion"; flow:to_server,established; content:"SSH-2.0-"; depth:8; classtype:command-and-control; sid:2000358; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

# RMM + Telegram correlation
alert tcp any any -> any any (msg:"Bark&Bite - Iranian APT RMM + Telegram Correlation Chain"; flowbits:isset,iranian.havoc; flowbits:isset,iranian.telegram; classtype:successful-admin; sid:2000359; rev:1; priority:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

