# Tracked as UAT-8616; CISA KEV Feb 25, 2026
# Observed: web shell deployment, API abuse, privilege escalation
#==============================================================================

# CVE-2026-20122: Cisco SD-WAN Manager API Arbitrary File Overwrite
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT CVE-2026-20122 Cisco SD-WAN API File Overwrite 2026"; flow:to_server,established; content:"PUT"; http_method; content:"/dataservice/"; http_uri; content:"../"; http_uri; distance:0; flowbits:set,iranian.sdwan; reference:cve,2026-20122; classtype:attempted-admin; sid:2000231; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

# CVE-2026-20128: Cisco SD-WAN DCA Credential Exposure
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Bark&Bite - Iranian APT CVE-2026-20128 Cisco SD-WAN DCA Cred Access 2026"; flow:to_server,established; content:"GET"; http_method; content:"/dataservice/"; http_uri; content:"dca"; http_uri; distance:0; within:50; content:"credential"; http_uri; distance:0; within:50; flowbits:set,iranian.sdwan.cred; reference:cve,2026-20128; classtype:credential-theft; sid:2000232; rev:1; metadata:policy max-detect-ips drop, created_at 2026_03_12, updated_at 2026_03_12;)

# Cisco SD-WAN web shell deployment post-exploitation
